object Outer
  val outerVal: String = …
  class Inner
    val innerVal: Int = …
    object DeepInner
      val deepVal: Boolean = …
      def deepMethod(x: Int): Int
      class Deepest
        def hello(): String
    def innerMethod(): Unit
  trait InnerTrait
    def abstractMethod(): String
    def concreteMethod(): Int
  object InnerObject extends InnerTrait
    val name: String = …
    def abstractMethod(): String
    def extra(): Boolean
  def outerMethod(i: Inner): String
