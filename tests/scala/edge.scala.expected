trait HasLogger
  lazy val logger: String = …
  def log(msg: String): Unit
object LazyVals
  lazy val expensiveComputation: Int = …
  lazy val cachedList: List[String] = …
  val eagerVal: Double = …
  lazy val anotherLazy: Boolean = …
  def useLazy(): Int
trait TypeMembers
  type Element
  type Container[A]
  type Mapping = Map[String, Element]
  def createElement(): Element
  def wrap[A](a: A): Container[A]
class LegacyImplicits
  implicit val defaultTimeout: Int = …
  implicit def stringToInt(s: String): Int
  def compute(x: Int)(implicit timeout: Int): String
  def process[A](items: List[A])(implicit ord: Ordering[A]): List[A]
object GivenUsing
  trait Show[A]
    def show(a: A): String
    def show(a: Int): String
    def show(a: List[A]): String
  def display[A](a: A)(using s: Show[A]): String
  def displayAll[A: Show](items: List[A]): String
class MultiParam
  def threeGroups(a: Int)(b: String, c: Boolean)(d: Double): String
  def curriedAdd(x: Int)(y: Int)(z: Int): Int
  def withContext[A](value: A)(using ctx: String, n: Int): String
object TypeAliases
  type StringMap[V] = Map[String, V]
  type Callback[A] = A => Unit
  type BiFunc[A, B, C] = (A, B) => C
  type NestedOption[A] = Option[Option[A]]
  val handlers: StringMap[Callback[Int]] = …
  lazy val registry: StringMap[List[String]] = …
  def register(key: String)(handler: Callback[Int]): StringMap[Callback[Int]]
  def lookup(key: String): Option[Callback[Int]]
class Malformed
  def noReturnType()
  def weirdSpacing (x : Int) : String
  def +(other: Malformed)
  def unary_-
