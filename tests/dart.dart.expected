abstract class Shape
  const Shape() = …
  double get area
  double get perimeter
  bool contains(Point<double> p)
  String toString()
mixin Serializable
  Map<String, dynamic> toJson()
  String toJsonString()
  static T? tryParse<T>(String json, T Function(Map<String, dynamic>) fromJson)
mixin Cacheable
  String get cacheKey
  Duration get cacheTtl
  bool isCacheStale(DateTime cachedAt)
abstract class Result<T>
  const Result() = …
  bool get isOk
  T get valueOrThrow
  R fold<R>({required R Function(T) onOk, required R Function(Object) onError})
class Ok<T> extends Result<T>
  final T value = …
  const Ok(this.value) = …
  bool get isOk
  T get valueOrThrow
  R fold<R>({required R Function(T) onOk, required R Function(Object) onError})
class Err<T> extends Result<T>
  final Object error = …
  const Err(this.error) = …
  bool get isOk
  T get valueOrThrow
  R fold<R>({required R Function(T) onOk, required R Function(Object) onError})
class Circle extends Shape with Serializable, Cacheable
  final double radius = …
  static const double pi = …
  const Circle(this.radius) = …
  double get area
  double get perimeter
  bool contains(Point<double> p)
  Map<String, dynamic> toJson()
  String get cacheKey
abstract mixin class Disposable
  bool get isDisposed
  void dispose()
  void assertNotDisposed()
