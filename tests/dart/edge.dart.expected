const String oldApiUrl = …
const int inlineHint = …
class Empty
abstract class Marker
  void mark()
  bool isMarked()
class Token
  final String kind = …
  final String value = …
  final int line = …
  const Token(this.kind, this.value, this.line) = …
  String toString() => 'Token($kind, $value)'
  Token copyWith({String? kind, String? value, int? line})
class HttpRequest
  final String method = …
  final Uri url = …
  final Map<String, String> headers = …
  final String? body = …
  final Duration timeout = …
  final bool followRedirects = …
  final int maxRedirects = …
  const HttpRequest({ required this.method, required this.url, this.headers = const {}, this.body, this.timeout = const Duration(seconds: 30), this.followRedirects = true, this.maxRedirects = 5, }) = …
  HttpRequest get(String path) => copyWith(method: 'GET', url: url.resolve(path))
  HttpRequest copyWith({ String? method, Uri? url, Map<String, String>? headers, String? body, Duration? timeout, bool? followRedirects, int? maxRedirects, })
Stream<int> countUp(int to) async*
Future<void> delay(int ms) => Future.delayed(Duration(milliseconds: ms))
typedef Predicate<T> = bool Function(T value)
typedef AsyncMapper<A, B> = Future<B> Function(A input)
typedef Json = Map<String, dynamic>
extension StringX on String
  String capitalize() => isEmpty ? this : '${this[0].toUpperCase()}${substring(1)}'
extension ListX<T> on List<T>
  List<T> separated(T separator)
class Dangling
  final int x = …
  int doubled() => x * 2
