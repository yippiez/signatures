  public interface IRepository<TEntity, TKey>
    TEntity? FindById(TKey id)
    IEnumerable<TEntity> FindAll()
    void Save(TEntity entity)
    bool Delete(TKey id)
  public class InMemoryRepository<TEntity, TKey> : IRepository<TEntity, TKey>
    public const int InitialCapacity = …
    public InMemoryRepository(Func<TEntity, TKey> keySelector)
    public IEnumerable<TEntity> FindAll()
    public void Save(TEntity entity)
    public bool Delete(TKey id)
  public sealed class Pipeline<TIn, TOut>
    private Pipeline(Func<TIn, TOut> step)
    public static Pipeline<TIn, TIn> Start()
    public TOut Run(TIn input)
  public static class GenericExtensions
    public static TResult ApplyOrDefault<TSource, TResult>(this TSource? source, Func<TSource, TResult> selector, TResult defaultValue)
    public static IEnumerable<T> WhereNotNull<T>(this IEnumerable<T?> source)
    public static void ForEach<T>(this IEnumerable<T> source, Action<T> action)
    public static TAccum Fold<TItem, TAccum>(this IEnumerable<TItem> source, TAccum seed, Func<TAccum, TItem, TAccum> accumulator)
