let schemaVersion: Int = …
struct Database
  let name: String = …
  var isOpen: Bool = …
  struct Table
    let tableName: String = …
    var rowCount: Int = …
    struct Column
      let columnName: String = …
      var dataType: String = …
      var isNullable: Bool = …
      func describe() -> String
    func column(named name: String) -> Column?
    mutating func addColumn(_ col: Column)
  enum StorageFormat
    struct Options
      var pageSize: Int = …
      var cacheSize: Int = …
      func isValid() -> Bool
    var options: Options = …
  func table(named name: String) -> Table?
  func open()
class DocumentStore
  var path: String = …
  class Section
    var title: String = …
    var items: [String] = …
    init(title: String)
    func addItem(_ item: String)
    class SubSection
      var heading: String = …
      init(heading: String)
      func render() -> String
  init(path: String)
  func newSection(title: String) -> Section
extension DocumentStore
  protocol Exportable
    func export() -> Data
    var mimeType: String = …
  func exportAll() -> [Data]
