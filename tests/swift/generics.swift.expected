let emptySlotSentinel: Int = …
func identity<T>(_ value: T) -> T
func zip<A, B>(_ a: [A], _ b: [B]) -> [(A, B)]
func sorted<T: Comparable>(_ collection: [T]) -> [T]
func transform<Input, Output>(_ values: [Input], using transform: (Input) throws -> Output) rethrows -> [Output]
func merge<Key: Hashable, Value>(_ lhs: [Key: Value], _ rhs: [Key: Value], resolving conflict: (Value, Value) -> Value) -> [Key: Value]
struct Stack<Element>
  private var storage: [Element] = …
  init()
  mutating func push(_ element: Element)
  mutating func pop() -> Element?
  var top: Element? = …
  var isEmpty: Bool = …
struct Pair<First, Second>
  let first: First = …
  let second: Second = …
  init(_ first: First, _ second: Second)
  func swapped() -> Pair<Second, First>
  func mapFirst<T>(_ f: (First) -> T) -> Pair<T, Second>
protocol Measurable
  var measure: Double = …
func largest<T: Measurable>(_ items: [T]) -> T?
func allEqual<T: Equatable>(_ lhs: [T], _ rhs: [T]) -> Bool
extension Array where Element: Comparable
  func clamp(min lower: Element, max upper: Element) -> [Element]
  var minMax: (min: Element, max: Element)? = …
extension Stack where Element: Equatable
  func contains(_ element: Element) -> Bool
protocol Container
  var count: Int = …
  func item(at index: Int) -> Item
  mutating func append(_ item: Item)
struct BoundedQueue<T>: Container
  typealias Item = T
  private var items: [T] = …
  let capacity: Int = …
  var count: Int = …
  init(capacity: Int)
  func item(at index: Int) -> T
  mutating func append(_ item: T)
  mutating func dequeue() -> T?
