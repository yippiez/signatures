let defaultTimeoutInterval: TimeInterval = …
let maxRetryCount: Int = …
struct User
  let id: UUID = …
  var username: String = …
  var email: String = …
  var avatarURL: URL? = …
  func displayName() -> String
  mutating func updateEmail(_ newEmail: String)
struct APIError
  let code: Int = …
  let message: String = …
  var isRetryable: Bool = …
protocol NetworkSession
  func data(from url: URL) async throws -> (Data, URLResponse)
  func upload(request: URLRequest, data: Data) async throws -> (Data, URLResponse)
protocol Endpoint
  var path: String = …
  var method: String = …
  var headers: [String: String] = …
class APIClient
  let baseURL: URL = …
  var session: NetworkSession = …
  private let decoder: JSONDecoder = …
  init(baseURL: URL, session: NetworkSession)
  func fetch<T: Decodable>(endpoint: any Endpoint) async throws -> T
  func post<Body: Encodable, Response: Decodable>(endpoint: any Endpoint, body: Body) async throws -> Response
class UserRepository
  private let client: APIClient = …
  private var cache: [UUID: User] = …
  init(client: APIClient)
  func fetchUser(id: UUID) async throws -> User
  func updateUser(_ user: User) async throws -> User
  func clearCache()
enum UserEndpoint: Endpoint
  var path: String = …
  var method: String = …
  var headers: [String: String] = …
