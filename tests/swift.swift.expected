@@CASE@@ edge
let _: Int = …
let __version__: String = …
func computeValue(_ x: Int, _ y: Int) -> Int
struct MathUtils
  static let goldenRatio: Double = …
  static var seed: UInt64 = …
  static func gcd(_ a: Int, _ b: Int) -> Int
  static func lcm(_ a: Int, _ b: Int) -> Int
class Registry
  var entries: [String: Any] = …
  class func shared() -> Registry
  init()
  subscript(key: String) -> Any?
  func register(key: String, value: Any)
protocol Greetable
  var name: String = …
  func greet() -> String
extension Greetable
  func greet() -> String
  func farewell() -> String
enum EmptyFlags
enum HTTPMethod: String
  var isIdempotent: Bool = …
typealias CompletionHandler = (Result<Data, Error>) -> Void
typealias JSONDict = [String: Any]
actor Counter
  var value: Int = …
  let step: Int = …
  init(start: Int = 0, step: Int = 1)
  func increment()
  func reset()
func multiParam(first: Int, second: String, third: Bool) -> String
func sum(_ numbers: Int...) -> Int
func swap(_ a: inout Int, _ b: inout Int)
@@CASE@@ generics
let emptySlotSentinel: Int = …
func identity<T>(_ value: T) -> T
func zip<A, B>(_ a: [A], _ b: [B]) -> [(A, B)]
func sorted<T: Comparable>(_ collection: [T]) -> [T]
func transform<Input, Output>(_ values: [Input], using transform: (Input) throws -> Output) rethrows -> [Output]
func merge<Key: Hashable, Value>(_ lhs: [Key: Value], _ rhs: [Key: Value], resolving conflict: (Value, Value) -> Value) -> [Key: Value]
struct Stack<Element>
  private var storage: [Element] = …
  init()
  mutating func push(_ element: Element)
  mutating func pop() -> Element?
  var top: Element? = …
  var isEmpty: Bool = …
struct Pair<First, Second>
  let first: First = …
  let second: Second = …
  init(_ first: First, _ second: Second)
  func swapped() -> Pair<Second, First>
  func mapFirst<T>(_ f: (First) -> T) -> Pair<T, Second>
protocol Measurable
  var measure: Double = …
func largest<T: Measurable>(_ items: [T]) -> T?
func allEqual<T: Equatable>(_ lhs: [T], _ rhs: [T]) -> Bool
extension Array where Element: Comparable
  func clamp(min lower: Element, max upper: Element) -> [Element]
  var minMax: (min: Element, max: Element)? = …
extension Stack where Element: Equatable
  func contains(_ element: Element) -> Bool
protocol Container
  var count: Int = …
  func item(at index: Int) -> Item
  mutating func append(_ item: Item)
struct BoundedQueue<T>: Container
  typealias Item = T
  private var items: [T] = …
  let capacity: Int = …
  var count: Int = …
  init(capacity: Int)
  func item(at index: Int) -> T
  mutating func append(_ item: T)
  mutating func dequeue() -> T?
@@CASE@@ nested
let schemaVersion: Int = …
struct Database
  let name: String = …
  var isOpen: Bool = …
  struct Table
    let tableName: String = …
    var rowCount: Int = …
    struct Column
      let columnName: String = …
      var dataType: String = …
      var isNullable: Bool = …
      func describe() -> String
    func column(named name: String) -> Column?
    mutating func addColumn(_ col: Column)
  enum StorageFormat
    struct Options
      var pageSize: Int = …
      var cacheSize: Int = …
      func isValid() -> Bool
    var options: Options = …
  func table(named name: String) -> Table?
  func open()
class DocumentStore
  var path: String = …
  class Section
    var title: String = …
    var items: [String] = …
    init(title: String)
    func addItem(_ item: String)
    class SubSection
      var heading: String = …
      init(heading: String)
      func render() -> String
  init(path: String)
  func newSection(title: String) -> Section
extension DocumentStore
  protocol Exportable
    func export() -> Data
    var mimeType: String = …
  func exportAll() -> [Data]
@@CASE@@ realworld
let defaultTimeoutInterval: TimeInterval = …
let maxRetryCount: Int = …
struct User
  let id: UUID = …
  var username: String = …
  var email: String = …
  var avatarURL: URL? = …
  func displayName() -> String
  mutating func updateEmail(_ newEmail: String)
struct APIError
  let code: Int = …
  let message: String = …
  var isRetryable: Bool = …
protocol NetworkSession
  func data(from url: URL) async throws -> (Data, URLResponse)
  func upload(request: URLRequest, data: Data) async throws -> (Data, URLResponse)
protocol Endpoint
  var path: String = …
  var method: String = …
  var headers: [String: String] = …
class APIClient
  let baseURL: URL = …
  var session: NetworkSession = …
  private let decoder: JSONDecoder = …
  init(baseURL: URL, session: NetworkSession)
  func fetch<T: Decodable>(endpoint: any Endpoint) async throws -> T
  func post<Body: Encodable, Response: Decodable>(endpoint: any Endpoint, body: Body) async throws -> Response
class UserRepository
  private let client: APIClient = …
  private var cache: [UUID: User] = …
  init(client: APIClient)
  func fetchUser(id: UUID) async throws -> User
  func updateUser(_ user: User) async throws -> User
  func clearCache()
enum UserEndpoint: Endpoint
  var path: String = …
  var method: String = …
  var headers: [String: String] = …
